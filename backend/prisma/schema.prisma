generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// USER MANAGEMENT
model UserProfile {
  id            String         @id @map("id")
  email         String         @unique @map("email")
  fullName      String?        @map("full_name")
  department    String?        @map("department")
  role          UserRole       @default(USER) @map("role")
  deptId        Int?           @map("dept_id")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  
  dept          DeptMaster?    @relation(fields: [deptId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  logs          ActivityLogs[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([deptId])
  @@index([role])
  @@map("user_profiles")
}

enum UserRole {
  ADMIN
  MANAGER
  USER

  @@map("user_role")
}

// CORE DOMAIN MODELS
model DeptMaster {
  id              Int                  @id @default(autoincrement()) @map("id")
  name            String               @unique @map("name")
  baseline        Decimal              @db.Decimal(12, 2) @map("baseline")
  description     String?              @map("description")
  manager         String?              @map("manager")
  isActive        Boolean              @default(true) @map("is_active")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  
  logs            ActivityLogs[]
  users           UserProfile[]
  analyticsCache  AnalyticsCache[]

  @@index([isActive])
  @@map("dept_master")
}

model EmissionRef {
  activityType  String           @id @map("activity_type")
  factor        Decimal          @db.Decimal(12, 6) @map("factor")
  unit          String           @map("unit")
  description   String?          @map("description")
  category      String?          @map("category")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  
  logs          ActivityLogs[]

  @@index([isActive])
  @@map("emission_ref")
}

model ActivityLogs {
  id            Int             @id @default(autoincrement()) @map("id")
  userId        String          @map("user_id")
  deptId        Int             @map("dept_id")
  activityId    String          @map("activity_id")
  units         Decimal         @db.Decimal(12, 3) @map("units")
  co2Result     Decimal         @db.Decimal(12, 3) @map("co2_result")
  notes         String?         @map("notes")
  timestamp     DateTime        @default(now()) @map("timestamp")
  createdAt     DateTime        @default(now()) @map("created_at")
  
  user          UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  dept          DeptMaster      @relation(fields: [deptId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  activity      EmissionRef     @relation(fields: [activityId], references: [activityType], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([deptId])
  @@index([activityId])
  @@index([timestamp])
  @@map("activity_logs")
}

// AUDIT & LOGGING
model AuditLog {
  id            Int             @id @default(autoincrement()) @map("id")
  userId        String?         @map("user_id")
  action        String          @map("action")
  entityType    String          @map("entity_type")
  entityId      String          @map("entity_id")
  oldValues     Json?           @map("old_values")
  newValues     Json?           @map("new_values")
  ipAddress     String?         @map("ip_address")
  userAgent     String?         @map("user_agent")
  timestamp     DateTime        @default(now()) @map("timestamp")
  
  user          UserProfile?    @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([timestamp])
  @@map("audit_logs")
}

// ANALYTICS CACHING
model AnalyticsCache {
  id              Int             @id @default(autoincrement()) @map("id")
  deptId          Int             @map("dept_id")
  totalEmissions  Decimal         @db.Decimal(16, 3) @map("total_emissions")
  baselineUsage   Decimal         @db.Decimal(12, 2) @map("baseline_usage")
  variance        Decimal         @db.Decimal(12, 3) @map("variance")
  percentOverage  Decimal         @db.Decimal(5, 2) @map("percent_overage")
  logCount        Int             @default(0) @map("log_count")
  lastUpdated     DateTime        @default(now()) @updatedAt @map("last_updated")
  cachedAt        DateTime        @default(now()) @map("cached_at")
  
  dept            DeptMaster      @relation(fields: [deptId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([deptId])
  @@index([deptId])
  @@map("analytics_cache")
}

// NOTIFICATIONS
model Notification {
  id            Int             @id @default(autoincrement()) @map("id")
  userId        String          @map("user_id")
  title         String          @map("title")
  message       String          @map("message")
  type          NotificationType @default(INFO) @map("type")
  relatedData   Json?           @map("related_data")
  isRead        Boolean         @default(false) @map("is_read")
  createdAt     DateTime        @default(now()) @map("created_at")
  readAt        DateTime?       @map("read_at")
  
  user          UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS

  @@map("notification_type")
}

// ADMIN RECORDS
model AdminAction {
  id            Int             @id @default(autoincrement()) @map("id")
  adminId       String          @map("admin_id")
  actionType    String          @map("action_type")
  targetType    String          @map("target_type")
  targetId      String          @map("target_id")
  description   String?         @map("description")
  status        String          @default("completed") @map("status")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([adminId])
  @@index([actionType])
  @@index([createdAt])
  @@map("admin_actions")
}